# ============================================================
# ADOPTIA — variables de entorno
# Copia a .env.local (Next.js) y rellena. NUNCA subas .env* al repo.
# ============================================================

# --- Supabase (obligatorio) ---
# Proyecto: https://supabase.com/dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...clave-anon-publica
# Solo servidor (Route Handlers) — jamás exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ...clave-service-role

# --- Email transaccional: SMTP de Gmail + plantillas propias (Decisión #22) ---
# Usa una "Contraseña de aplicación" de Google (no la del usuario).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=tu-cuenta@gmail.com
SMTP_PASS=app-password-de-16-caracteres
MAIL_FROM="Adoptia <tu-cuenta@gmail.com>"

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Correo de soporte (botón "Contactar soporte" del panel). Público.
NEXT_PUBLIC_SUPPORT_EMAIL=hola@adoptia.app

# --- Cloudflare Turnstile (CAPTCHA en auth) ---
# Site key PÚBLICA (va al cliente). El secret se configura en Supabase, no aquí.
# En local/tests usa la clave de prueba que siempre pasa: 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# --- Sentry (monitorización de errores, free tier) ---
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# --- Analítica (Umami cloud free — sin cookies, RGPD-friendly) ---
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# --- Cron jobs (keepalive Supabase, backups) ---
# Secreto para proteger los endpoints /api/cron/*
CRON_SECRET=cambia-esto-por-un-secreto-largo

# --- Tests de RLS (stack local: npx supabase start && npx supabase status) ---
SUPABASE_TEST_URL=http://127.0.0.1:54321
SUPABASE_TEST_ANON_KEY=eyJ...anon-del-stack-local
SUPABASE_TEST_SERVICE_ROLE_KEY=eyJ...service-role-del-stack-local
